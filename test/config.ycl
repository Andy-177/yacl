# ============================================
# YACL 完整测试配置文件
# 覆盖所有语法特性和边界情况
# ============================================

# --- 基础键值对 ---
基本测试:
    单引号字符串: '这一整行都是字符串，即使有 # 和特殊字符 !@#$%^&*()
    双引号字符串: "只有这部分是字符串，# 之后的内容是注释
    整数: 42
    负数: -999
    浮点数: 3.14159
    负浮点数: -0.001
    布尔_true: true
    布尔_false: false
    布尔_on: on
    布尔_off: off
    布尔_enabled: enabled
    布尔_disabled: disabled
    空值: none

# --- 键名测试 ---
键名测试:
    中文键: '中文键值
    key_with_underscore: '下划线键
    key-with-dash: '短横线键
    key.with.dot: '点号键
    key with spaces: '带空格的键
    CamelCaseKey: '驼峰键
    123数字开头: '数字开头键

# --- 列表测试 ---
列表测试:
    字符串列表:
        - '苹果
        - '香蕉
        - '橙子
    数字列表:
        - 1
        - 2
        - 3
    混合列表:
        - '字符串
        - 42
        - true
        - none
    嵌套列表:
        -
            - 1
            - 2
            - 3
        -
            - 4
            - 5
            - 6
        -
            - 7
            - 8
            - 9
    空列表项:
        -
        -
        -

# --- 对象嵌套测试 ---
对象测试:
    一级:
        二级:
            三级:
                四级:
                    深度值: ' deeply nested

# --- 引用测试 ---
引用源:
    姓名: 'Alice
    年龄: 30
    爱好:
        - '阅读
        - '游戏
        - '编程
    地址:
        城市: '北京
        邮编: 100000

引用测试:
    引用姓名: [引用源].[姓名]
    引用年龄: [引用源].[年龄]
    引用城市: [引用源].[地址].[城市]
    第一个爱好: [引用源].[爱好].0
    第二个爱好: [引用源].[爱好].1
    第三个爱好: [引用源].[爱好].2

# --- 三引号块测试 ---
三引号测试:
    单引号多行: '''
        第一行
        第二行
        包含 # 号的行
        最后一行
        '''
    双引号多行: """
        第一行保留
        # 这一行是注释，被移除
        第二行保留
        # 这行也被移除
        第三行保留
        """
    单引号紧凑: '''aaa
bbb'''
    双引号紧凑: """xxx
# 注释被移除
yyy"""

# --- 块标量 | 依赖缩进模式 ---
块标量单管道缩进:
    保留注释: |
        第一行文本
        第二行文本
        # 这是注释，但被保留
            缩进的第四行
    同级键: '这个键和上面的块同级

# --- 块标量 || 依赖缩进模式 ---
块标量双管道缩进:
    移除注释: ||
        第一行文本
        # 这是注释，被移除
        key: '这看起来是键值对，但属于块内容
        第三行文本
    真正的同级键: '我是独立的键

# --- 块标量 | 带行数模式 ---
块标量单管道行数:
    保留三行: |3
第一行，无缩进
# 注释被保留
    第三行，前面有空格
    这是同级键，不是块内容

# --- 块标量 || 带行数模式 ---
块标量双管道行数:
    取两行非注释: ||2
第一行文本
# 注释被忽略，不计入行数
第二行文本
# 这也被忽略
第三行，超出行数限制
    同级键: '独立键

# --- 注释测试 ---
注释测试:
    行内注释: 42 # 这是行内注释
    字符串中无注释: '这个 # 不是注释
    双引号字符串注释: "字符串 # 注释开始

###
这是多行注释块。
可以包含 # 等特殊字符。
不影响解析。
###

    多行注释后: '多行注释后的值

# --- 边界情况 ---
边界情况:
    空字符串单引号: '
    空字符串双引号: "
    仅空格单引号: '   
    仅空格双引号: "   
    零: 0
    负零: -0
    大数: 9999999999
    小数: 0.0000001
    科学计数法: 1e10
    特殊字符串: 'true
    特殊字符串2: 'none
    特殊字符串3: '42

# --- 复杂嵌套 ---
复杂配置:
    服务器:
        - 主机: 'server1.example.com
          端口: 8080
          标签:
              - 'web
              - 'api
        - 主机: 'server2.example.com
          端口: 8081
          标签:
              - 'db
              - 'cache
    数据库连接:
        主库:
            驱动: 'postgresql
            连接串: 'postgresql://user:pass@localhost:5432/db
            池配置:
                最小连接: 5
                最大连接: 20
                超时: 30
        从库:
            驱动: 'mysql
            连接串: 'mysql://user:pass@replica:3306/db
            池配置:
                最小连接: 2
                最大连接: 10
                超时: 15

# --- 引用复杂嵌套 ---
引用复杂:
    主库驱动: [复杂配置].[数据库连接].[主库].[驱动]
    第一个服务器主机: [复杂配置].[服务器].0.[主机]
    第一个服务器第一个标签: [复杂配置].[服务器].0.[标签].0

# --- 空行和特殊字符 ---
特殊字符:
    换行符测试: '包含\\n的字符串
    制表符测试: '包含\\t的字符串
    反斜杠: '包含\\\\的字符串
    引号: '包含"和\'的字符串
    Unicode: '包含Emoji 😀和中文🎉

# --- 多行块边界测试 ---
多行边界:
    开始换行修剪: '''
aaa
bbb
'''
    结束换行修剪: '''aaa
bbb'''
    两边换行修剪: '''
aaa
bbb'''
    无换行: '''aaa
bbb'''

# --- 块标量空行测试 ---
空行测试:
    保留空行: |4
第一行

第三行（前面有空行）

第五行（前面有空行）
    结束: true

# --- 最终验证 ---
验证:
    所有类型已测试: true
    测试完成: enabled